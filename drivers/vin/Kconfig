menu "VIN (camera) Drivers"
	depends on AW_BSP

config AW_VIDEO_SUNXI_VIN
       tristate "sunxi video input (camera csi/mipi isp vipp) driver"
	   select MEDIA_SUPPORT
       default n

config AW_SENSOR_POWER
       tristate "sensor power in front of vin"
       depends on AW_VIDEO_SUNXI_VIN
       default n
config CSI_VIN
	tristate "v4l2 new driver for SUNXI"
	depends on AW_VIDEO_SUNXI_VIN
	default m
	select VIDEOBUF2_DMA_CONTIG

config ENABLE_SENSOR_FLIP_OPTION
	bool "select sensor flip to replace vipp flip"
	depends on AW_VIDEO_SUNXI_VIN
	default n
	help
	   you cant flip in vipp when you select LBC format,
	   so you can enable it to active sensor flip operation.

config VIDEO_SUNXI_VIN_SPECIAL
	bool "special function for vin"
	depends on AW_VIDEO_SUNXI_VIN
	default n
	help
	   if say Y, some special function will be support for
           some scence, such as fast car reverse and so on.

config SET_BK_BUF_OFFSET
	bool "bk buffer need offset some byte"
	depends on VIDEO_SUNXI_VIN_SPECIAL
	default n

config CSI_CCI
	tristate "use cci function"
	depends on AW_VIDEO_SUNXI_VIN
	default n
	help
		CCI is a hardware module in CSI. you can make it to
		be cci or i2c in the system.

if CSI_CCI
source "$(BSP_TOP)drivers/vin/vin-cci/Kconfig"
endif

config FLASH
	tristate "use flash module"
	depends on AW_VIDEO_SUNXI_VIN
	default m

config ACTUATOR
	tristate "use actuator module"
	depends on AW_VIDEO_SUNXI_VIN
	default n

if ACTUATOR
source "$(BSP_TOP)drivers/vin/modules/actuator/Kconfig"
endif

config SENSOR_LIST
	tristate "sensor list for adaptive"
	depends on AW_VIDEO_SUNXI_VIN
	default m

config BUF_AUTO_UPDATE
	bool "buf addr update for hardware"
	depends on AW_VIDEO_SUNXI_VIN
	default n

config BUF_GET_FRAME_DONE
	bool "buf get in frame done"
	depends on AW_VIDEO_SUNXI_VIN
	default n

config VIN_LOG
	bool "use vin log for debug"
	depends on AW_VIDEO_SUNXI_VIN
        depends on DYNAMIC_DEBUG
	default y

config PIPELINE_RESET
	bool "use pipeline reset when timeout"
	depends on AW_VIDEO_SUNXI_VIN
	default n

config MULTI_FRAME
	bool "multi-frame interrupt mode"
	depends on AW_VIDEO_SUNXI_VIN
	default n

config SUPPORT_ISP_TDM
	bool "use isp for time sharing multiplex"
	depends on AW_VIDEO_SUNXI_VIN
	default n

config TDM_LBC_EN
	bool "tdm reduces buf size by compression"
	depends on SUPPORT_ISP_TDM
	default n

config TDM_ONE_BUFFER
	bool "tdm use one buffer mode"
	depends on SUPPORT_ISP_TDM
	default n
	help
		need ensure sensor vbland > 20%

config TDM_USE_BK_BUFFER
	bool "tdm use bk buffer"
	depends on TDM_ONE_BUFFER
	default n

config TDM_ONE_BUFFER_WITH_TWORX
	bool "tdm use one buffer mode with two tdm_rx run"
	depends on TDM_ONE_BUFFER
	default n

config TDM_OFFLINE_HANDLE_RAW
	bool "tdm receive raw data to user and than get it from user, finally return to isp"
	depends on SUPPORT_ISP_TDM
	default n

config AVG_TDM_FIFO
	bool "set the tdm four channels fifo the same"
	depends on SUPPORT_ISP_TDM
	default n

config SOFTWARE_TDM_FOR_ISP
	bool "use isp for software time sharing multiplex"
	depends on AW_VIDEO_SUNXI_VIN
	default n

choice
	depends on AW_VIDEO_SUNXI_VIN
	prompt "select rgb mode"
	default VIPP_YUV2RGB

config SENSOR_RGB
	bool "sensor output rgb"

config VIPP_YUV2RGB
	bool "vipp yuv to rgb"

endchoice

config MULTI_FRM_MERGE_INT
	bool "multi-frame image merge interrupt"
	depends on AW_VIDEO_SUNXI_VIN
	default n

config DEF_MEDIA_LINK
	bool "set default media link"
	depends on AW_VIDEO_SUNXI_VIN
	default n

config DISPPLAY_SYNC
	bool "use one buffer for delay display"
	depends on AW_VIDEO_SUNXI_VIN
	default n

choice
	depends on AW_VIDEO_SUNXI_VIN
	prompt "select memory alloc mode"
	default VIN_CMA

config VIN_CMA
	bool "use CMA for memory alloc"

config VIN_IOMMU
	bool "use IOMMU for memory alloc"

config VIN_USE_ION_SIZE_POOL_HEAP
	bool "use memory pool for memory alloc"

endchoice

config D3D
	bool "ISP 3D denoise module"
	depends on AW_VIDEO_SUNXI_VIN
	default n

config D3D_LTF_EN
	bool "ISP 3D denoise long time frame"
	depends on D3D
	depends on AW_VIDEO_SUNXI_VIN
	default n

choice
	depends on D3D
	prompt "select d3d mode"
	default D3D_PKG_MODE

config D3D_PKG_MODE
	bool "use d3d pkg mode"

config D3D_LBC_MODE
	bool "use d3d lbc mode"
endchoice

config D3D_COMPRESS_EN
	bool "ISP 3D denoise reduces buf size by compression"
	depends on AW_VIDEO_SUNXI_VIN
	depends on D3D
	depends on D3D_LBC_MODE
	default	n

config WDR
	bool "ISP WDR module"
	depends on AW_VIDEO_SUNXI_VIN
	default n

config WDR_COMPRESS_EN
	bool "ISP WDR reduces buf size by compression"
	depends on AW_VIDEO_SUNXI_VIN
	depends on WDR
	default	n

config FRAMEDONE_TWO_BUFFER
	bool "use two buffer in bk frame done interrupt"
	depends on AW_VIDEO_SUNXI_VIN
	default	n

config SAME_I2C
	bool "sensor same i2c addr"
	depends on AW_VIDEO_SUNXI_VIN
	default y

config VIN_SDRAM_DFS
	bool "use vin sdram dfs"
	depends on AW_VIDEO_SUNXI_VIN
	default n

config CSI_SDRAM_DFS_TEST
	bool "sensor first debug for sdram dfs"
	depends on VIN_SDRAM_DFS
	default n

config ISP_SERVER_MELIS
	bool "use ISP server from melis"
	depends on AW_VIDEO_SUNXI_VIN
	default n

config ISP_SPECIAL_LDCI
	bool "use isp ldci on fastboot"
	depends on ISP_SERVER_MELIS
	default n

config RPMSG_SEND_ISP_PARA
	bool "use rpmsg send isp para to rtos"
	depends on ISP_SERVER_MELIS
	default n

config VIN_INIT_MELIS
	bool "vin and isp init in melis"
	depends on AW_VIDEO_SUNXI_VIN
	default n

config ISP0_THRESHOLD_PARAM_OFFSET
	int "isp0 threshold param offset(sector)"
	default 111
	help
	  This section is located between boot0 and uboot.
	  Must ensure that the offset of this section is not less than the size of boot0.
	  The sizeof of the boot0&uboot reserved section is defined at the 'flashmap'
	  dts node in uboot-board.dts.

config ISP1_THRESHOLD_PARAM_OFFSET
	int "isp1 threshold param offset(sector)"
	default 119
	help
	  This section is located between boot0 and uboot.
	  Must ensure that the offset of this section is not less than the size of boot0.
	  The sizeof of the boot0&uboot reserved section is defined at the 'flashmap'
	  dts node in uboot-board.dts.

config VIN_THRESHOLD_PARAM_SIZE
	hex "vin threshold param size"
	default 0x200

config RV_RUN_CAR_REVERSE
	bool "special function for vin used on rv"
	depends on VIN_INIT_MELIS && VIDEO_SUNXI_VIN_SPECIAL
	default n

config ISP_REG_DEBUG_NODE
	bool "open isp register debug node"
	depends on AW_VIDEO_SUNXI_VIN
	default n

config VIN_SENSOR_RESERVE_ADDR
	hex "addr for vin sensor server"
	default 0x81CEE000

config RESUME_SENSOR_IN_SRAM
	bool "resume sensor in sram"
	depends on PM_SLEEP
	default n
	help
	  This section is declaration the sensor was resumed in sram.

source "$(BSP_TOP)drivers/vin/modules/sensor/Kconfig"

endmenu
