config V821_FMAC_WLAN
	tristate "v821 dual protocol stack support"
	default n
	help
	  To compile this code as a module, choose M here.

if V821_FMAC_WLAN

config V821_FMAC_RPMSG
	tristate "Support RPMSG platforms"
	depends on V821_FMAC_WLAN && RPMSG
	help
	  Enable support for the XRADIO connected via an RPMSG bus.

config V821_FMAC_SDIO
	tristate "Support SDIO platforms"
	depends on V821_FMAC_WLAN && MMC
	help
	  Enable support for the XRADIO connected via an SDIO bus.
	  By default this driver only supports the Sagrad XR819S/XR821 EVK
	  and similar designs that utilize a hardware reset circuit. To
	  support different XRADIO SDIO designs you will need to override
	  the default platform data by calling xradio_sdio_set_platform_data()
	  in your board setup file.

config V821_FMAC_SPI
	tristate "Support SPI platforms"
	depends on V821_FMAC_WLAN && SPI
	help
	  Enables support for the XRADIO connected via a SPI bus.  You will
	  need to add appropriate platform data glue in your board setup
	  file.

endif
