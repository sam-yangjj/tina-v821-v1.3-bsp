# LRADC drivers configuration
#

menu "Low Rate ADC Drivers"
	depends on AW_BSP


config AW_LRADC
	tristate "Keyboard Support for Allwinner SoCs"
	select INPUT_EVDEV
	help
	  Say Y here to enable the ADC keyboard, support 7 keys at most.

config AW_LRADC_DYNAMIC_DEBUG
        bool "Enable lradc dynamic debug"
        depends on AW_LRADC
        default y
        help
          Enable lradc dynamic debug

endmenu
