# Allwinner remoteproc driver.
#
menu "Remoteproc drivers"
	depends on AW_BSP

config AW_REMOTEPROC
	tristate "Remoteproc Support for Allwinner SoCs"
	depends on AW_BSP
	select REMOTEPROC
	select MAILBOX
	help
	  allwinner

config AW_RPMSG_RX_IN_KTHREAD
	bool "Receiving rpmsg in realtime kthread"
	depends on AW_REMOTEPROC
	default y
	help
	  Receiving rpmsg data in the realtime kernel thread.
	  It can improve the priority of rpmsg handling
	  and avoid the virtio buffer is exhausted.
	  Otherwise it will use workqueue to receive
	  rpmsg data.

config AW_RPROC_FAST_BOOT
	bool "Allwinner remoteproc fast boot mode support"
	depends on AW_REMOTEPROC
	default n
	help
	  Say y here to support Allwinner remote processor
	  fast boot mode.
	  This mode can speed up init operation.

config AW_RPROC_ENHANCED_TRACE
	bool "Allwinner remoteproc enhanced trace"
	depends on AW_REMOTEPROC
	default y
	help
	  Say y here to support Allwinner remote processor
	  enhanced trace function.

config AW_RPROC_SUBDEV
	bool "Allwinner remoteproc subdev support"
	depends on AW_REMOTEPROC
	default n
	help
	  Say y here to support subdev for Allwinner remote processor.

config AW_RPROC_SUBDEV_WDT
	bool "Allwinner remoteproc wdt subdev support"
	depends on AW_RPROC_SUBDEV
	default n
	help
	  Say y here to support wdt subdev for Allwinner remote processor.

config AW_RPROC_SUBDEV_RSC_HELPER
	bool "Allwinner remoteproc rsc helper subdev support"
	depends on AW_RPROC_SUBDEV
	default n
	help
	  Say y here to support rsc helper subdev for Allwinner remote processor.

config AW_RPROC_SUBDEV_STANDBY
	bool "Allwinner standby subdev support"
	depends on AW_RPROC_SUBDEV && AW_REMOTEPROC_E907_STANDBY
	default n
	help
	  Say y here to support standby subdev for Allwinner remote processor.

config AW_RPROC_SUBDEV_ECC
	bool "Allwinner remoteproc ecc subdev support"
	depends on AW_RPROC_SUBDEV && AW_REMOTEPROC_E907_ECC_ENABLE
	default n
	help
	  Say y here to support ecc subdev for Allwinner remote processor.

config AW_RPROC_USER_RESOURCE
	bool "Allwinner remoteproc handle rsc of user data"
	depends on AW_RPROC_SUBDEV_RSC_HELPER
	default n
	help
	  Say y here to support handle the rsc of user data .

config SUNXI_RPROC_SHARE_IRQ
	bool "SUNXI remote share irq support"
	depends on AW_REMOTEPROC
	default n
	help
	  Say y here to support SUNXI remote share irq driver.

config AW_REMOTEPROC_HIFI4_BOOT
	tristate "Allwinner remoteproc hifi4 boot"
	depends on AW_REMOTEPROC
	help
	  Say y here to support Allwinner SOC processors hifi4 via
	  remote processor framework.

config AW_REMOTEPROC_E906_BOOT
	tristate "Allwinner remoteproc e906 boot"
	depends on AW_REMOTEPROC
	help
	  Say y here to support Allwinner SOC processors e906 via
	  remote processor framework.

config AW_REMOTEPROC_E906_STANDBY
	bool "Allwinner remoteproc e906 standby"
	default n
	depends on AW_REMOTEPROC_E906_BOOT
	help
	  Say y here to support Allwinner SOC processors e906 standby

config AW_REMOTEPROC_E907_BOOT
	tristate "Allwinner remoteproc e907 boot"
	depends on AW_REMOTEPROC
	default n
	help
	  Say y here to support boot Allwinner SOC processors e907 via
	  remote processor framework.

config AW_REMOTEPROC_E907_STANDBY
	bool "Allwinner remoteproc e907 standby"
	default n
	depends on AW_REMOTEPROC_E907_BOOT
	help
	  Say y here to support Allwinner SOC processors e907 standby

config AW_REMOTEPROC_E907_STOP_NOTIFY
	bool "Allwinner remoteproc e907 stop notify"
	default n
	depends on AW_REMOTEPROC_E907_BOOT
	help
	  Say y here to support Allwinner SOC processors e907 stop notify

config AW_REMOTEPROC_E907_ECC_ENABLE
	tristate "Allwinner remoteproc e90X ECC funtion enable"
	depends on AW_REMOTEPROC && AW_REMOTEPROC_E907_BOOT
	default n
	help
	  Say y here to support e907 ecc function

config AW_REMOTEPROC_ARM64_BOOT
	tristate "Allwinner remoteproc arm64 boot"
	depends on AW_REMOTEPROC
	default n
	help
	  Say y here to support Allwinner SOC processors arm64 via
	  remote processor framework.

config AW_REMOTEPROC_DECOMPRESS_FW
	tristate "Allwinner remoteproc decompress firmware from partition"
	depends on AW_REMOTEPROC
	default n
	help
	  Say y here to support Allwinner decompress firmware

config AW_REMOTEPROC_DECOMPRESS_FW_SIZE
	hex "Allwinner remoteproc decompress firmware size"
	depends on AW_REMOTEPROC_DECOMPRESS_FW
	default 0x200000
	help
	  set decompress elf size

config AW_REMOTEPROC_USE_UNLZMA
	tristate "Allwinner remoteproc decompress use lzma lib"
	depends on AW_REMOTEPROC && AW_REMOTEPROC_DECOMPRESS_FW
	select DECOMPRESS_LZMA
	default n
	help
	  Say y here to support unlzma

config AW_REMOTEPROC_USE_UNGZIP
	tristate "Allwinner remoteproc decompress use gzip lib"
	depends on AW_REMOTEPROC && AW_REMOTEPROC_DECOMPRESS_FW
	select DECOMPRESS_GZIP
	default n
	help
	  Say y here to support ungzip

config AW_REMOTEPROC_USE_UNLZ4
	tristate "Allwinner remoteproc decompress use lz4 lib"
	depends on AW_REMOTEPROC && AW_REMOTEPROC_DECOMPRESS_FW
	select DECOMPRESS_LZ4
	default n
	help
	  Say y here to support unlz4

endmenu
